{
  "manifest_version": 3,
  "name": "NOCAP - Fake News Detector",
  "version": "1.0",
  "description": "On-device AI credibility indicator for YouTube videos.",
  "action": {
    "default_title": "Open NOCAP"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-Dwo9STcx.js"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "resources": [
        "shadow-ui.js",
        "content.css",
        "assets/content.ts-Dwo9STcx.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "permissions": []
}
